# ── Video-Use Platform Configuration ──────────────────────────────────

# App port (mapped to Nginx)
APP_PORT=8880

# Secret key for JWT (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=video-use-secret-key-change-me-2024

# ElevenLabs API Key (for Scribe transcription)
ELEVENLABS_API_KEY=

# Google Cloud API Key (for Speech-to-Text)
GOOGLE_TTS_API_KEY=

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=sqlite+aiosqlite:////app/data/db/video_use.db
